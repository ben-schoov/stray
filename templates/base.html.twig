<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Stray{% endblock %}</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --bg: #0b1220;
            --bg-soft: #111a2b;
            --surface: #162033;
            --surface-2: #1b2740;
            --text: #ecf3ff;
            --muted: #9fb0c9;
            --accent: #4caf7d;
            --accent-2: #7bd8a5;
            --border: rgba(255, 255, 255, 0.08);
            --shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
            --radius: 18px;
            --max-width: 1120px;
        }

        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at top left, rgba(76, 175, 125, 0.12), transparent 28%),
                radial-gradient(circle at top right, rgba(123, 216, 165, 0.08), transparent 22%),
                linear-gradient(180deg, #0a1120 0%, #0d1626 100%);
            min-height: 100vh;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .container {
            width: min(var(--max-width), calc(100% - 2rem));
            margin: 0 auto;
        }

        .site-header {
            position: sticky;
            top: 0;
            z-index: 10;
            backdrop-filter: blur(12px);
            background: rgba(11, 18, 32, 0.78);
            border-bottom: 1px solid var(--border);
        }

        .site-header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 0;
        }

        .brand {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text);
        }

        .brand-mark {
            width: 2.2rem;
            height: 2.2rem;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(76, 175, 125, 0.25), rgba(123, 216, 165, 0.1));
            border: 1px solid rgba(123, 216, 165, 0.25);
            color: var(--accent-2);
            font-size: 1.1rem;
            box-shadow: 0 0 20px rgba(76, 175, 125, 0.18);
        }

        .brand-text {
            letter-spacing: 0.01em;
        }

        .nav {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .nav a {
            color: var(--muted);
            font-weight: 600;
            transition: color 0.15s ease;
            padding-bottom: 0.2rem;
            border-bottom: 2px solid transparent;
        }

        .nav a:hover,
        .nav a.active {
            color: var(--accent-2);
            border-bottom-color: var(--accent);
        }

        .profile-link {
            font-size: 1.15rem;
            line-height: 1;
        }

        .hero {
            padding: 4rem 0 2rem;
        }

        .hero-card {
            position: relative;
            overflow: hidden;
            background:
                linear-gradient(135deg, rgba(76, 175, 125, 0.12), rgba(22, 32, 51, 0.95)),
                var(--surface);
            border: 1px solid var(--border);
            border-radius: 28px;
            padding: 2.5rem;
            box-shadow: var(--shadow);
        }

        .hero-card::after {
            content: "";
            position: absolute;
            inset: auto -40px -40px auto;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(123, 216, 165, 0.22), transparent 68%);
            pointer-events: none;
        }

        .hero h1 {
            margin: 0 0 0.8rem;
            font-size: clamp(2.5rem, 5vw, 4rem);
            line-height: 1;
        }

        .hero p {
            margin: 0;
            color: var(--muted);
            font-size: 1.08rem;
            max-width: 720px;
            line-height: 1.6;
        }

        .section-title {
            margin: 2.25rem 0 1rem;
            font-size: 1.6rem;
        }

        .places-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 340px));
            gap: 1rem;
            padding-bottom: 3rem;
        }

        .place-card {
            display: block;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem;
            box-shadow: var(--shadow);
            transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
            max-width: 340px;
        }

        .place-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 42px rgba(0, 0, 0, 0.34);
            border-color: rgba(123, 216, 165, 0.28);
        }

        .place-category {
            display: inline-block;
            margin-bottom: 0.8rem;
            padding: 0.35rem 0.65rem;
            border-radius: 999px;
            background: rgba(76, 175, 125, 0.16);
            color: var(--accent-2);
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .place-card h3 {
            margin: 0 0 0.55rem;
            font-size: 1.18rem;
            color: var(--text);
        }

        .place-card p {
            margin: 0 0 0.9rem;
            color: var(--muted);
            line-height: 1.55;
        }

        .place-meta {
            font-size: 0.9rem;
            color: var(--muted);
        }

        .site-footer {
            border-top: 1px solid var(--border);
            background: rgba(9, 14, 24, 0.7);
        }

        .site-footer-inner {
            padding: 1rem 0;
            font-size: 0.95rem;
            color: var(--muted);
        }
    </style>
</head>
<body>
<header class="site-header">
    <div class="container site-header-inner">
        <a class="brand" href="{{ path('app_home') }}">
            <span class="brand-mark">🍃</span>
            <span class="brand-text">Stray</span>
        </a>

        <nav class="nav">
            <a href="{{ path('app_home') }}" class="{{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">Home</a>
            <a href="{{ path('app_places') }}" class="{{ app.request.attributes.get('_route') == 'app_places' ? 'active' : '' }}">Places</a>
            <a href="{{ path('app_routes') }}" class="{{ app.request.attributes.get('_route') == 'app_routes' ? 'active' : '' }}">Routes</a>
            <a href="{{ path('app_events') }}" class="{{ app.request.attributes.get('_route') == 'app_events' ? 'active' : '' }}">Events</a>
            <a href="{{ path('app_profile') }}" class="profile-link {{ app.request.attributes.get('_route') == 'app_profile' ? 'active' : '' }}">👤</a>
        </nav>
    </div>
</header>

{% block body %}{% endblock %}

<footer class="site-footer">
    <div class="container site-footer-inner">
        Stray · Discover interesting places in Leuven
    </div>
</footer>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
