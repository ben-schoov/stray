{% extends 'base.html.twig' %}

{% block title %}Stray{% endblock %}

{% block body %}
    <main>
        <section class="hero">
            <div class="container">
                <div class="hero-card">
                    <h1>{{ app_name }}</h1>
                    <p>{{ tagline }}</p>
                </div>

                <h2 class="section-title">Places to explore</h2>

                {% if places is empty %}
                    <p>No places found yet.</p>
                {% else %}
                    <div class="places-grid">
                        {% for place in places %}
                            <a href="{{ path('app_place_detail', { slug: place.slug }) }}" class="place-card">
                                <div class="place-category">{{ place.category }}</div>
                                <h3>{{ place.name }}</h3>
                                <p>{{ place.description }}</p>
                                <div class="place-meta">
                                    {{ place.latitude }}, {{ place.longitude }}
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </section>
    </main>
{% endblock %}
