{% extends 'base.html.twig' %}

{% block title %}Places · Stray{% endblock %}

{% block body %}
    <main class="container page-section">
        <h1 class="page-title">Places</h1>
        <p class="page-subtitle">
            Explore places on the map and in the list below.
        </p>

        <div class="control-bar">
            <select id="category-filter" class="control-select">
                <option value="">All categories</option>
                <option value="park">Park</option>
                <option value="historic">Historic</option>
                <option value="square">Square</option>
                <option value="museum">Museum</option>
                <option value="viewpoint">Viewpoint</option>
            </select>

            <label class="control-checkbox">
                <input type="checkbox" id="hidden-filter">
                Hidden gems only
            </label>

            <select id="sort-filter" class="control-select">
                <option value="name-asc">Sort: Name A–Z</option>
                <option value="name-desc">Sort: Name Z–A</option>
                <option value="category-asc">Sort: Category A–Z</option>
            </select>
        </div>

        <section id="places-map-section" class="map-panel">
            <div id="map" class="map-canvas"></div>
        </section>

        <section>
            <h2 class="section-title">All places</h2>

            {% if places is empty %}
                <p class="empty-state">No places found yet.</p>
            {% else %}
                <div class="places-grid" id="places-grid">
                    {% for place in places %}
                        <article
                            class="place-card"
                            id="place-{{ place.id }}"
                            data-place-id="{{ place.id }}"
                            data-name="{{ place.name|lower }}"
                            data-category="{{ place.category }}"
                            data-hidden="{{ place.isHiddenGem ? '1' : '0' }}"
                            style="cursor: pointer;"
                        >
                            <div class="place-category">{{ place.category }}</div>
                            <h3>{{ place.name }}</h3>
                            <p>{{ place.description }}</p>
                            <div class="place-meta">
                                {{ place.latitude }}, {{ place.longitude }}
                            </div>
                            <a
                                href="{{ path('app_place_detail', { slug: place.slug }) }}"
                                class="place-link"
                            >
                                View details →
                            </a>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}

{% block javascripts %}
    <script>
        const markers = {};
        const mapSection = document.getElementById('places-map-section');
        const categoryFilter = document.getElementById('category-filter');
        const hiddenFilter = document.getElementById('hidden-filter');
        const sortFilter = document.getElementById('sort-filter');
        const placesGrid = document.getElementById('places-grid');

        const map = L.map('map').setView([50.8798, 4.7005], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        function activateCard(card) {
            document.querySelectorAll('.place-card').forEach((item) => {
                item.classList.remove('is-active');
            });

            if (card) {
                card.classList.add('is-active');

                setTimeout(() => {
                    card.classList.remove('is-active');
                }, 1500);
            }
        }

        {% for place in places %}
        const marker{{ place.id }} = L.marker([{{ place.latitude }}, {{ place.longitude }}])
            .bindPopup("<strong>{{ place.name }}</strong><br>{{ place.category }}");

        markers[{{ place.id }}] = marker{{ place.id }};
        marker{{ place.id }}.addTo(map);

        marker{{ place.id }}.on('click', function () {
            const el = document.getElementById('place-{{ place.id }}');

            if (el && el.style.display !== 'none') {
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                activateCard(el);
            }
        });
        {% endfor %}

        document.querySelectorAll('.place-card').forEach((card) => {
            card.addEventListener('click', function (event) {
                if (event.target.tagName.toLowerCase() === 'a') {
                    return;
                }

                const placeId = this.dataset.placeId;
                const marker = markers[placeId];

                if (marker) {
                    mapSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    map.setView(marker.getLatLng(), 15);
                    marker.openPopup();
                    activateCard(this);
                }
            });
        });

        function applyFilters() {
            const category = categoryFilter.value;
            const hiddenOnly = hiddenFilter.checked;

            document.querySelectorAll('.place-card').forEach((card) => {
                const placeId = card.dataset.placeId;
                const cardCategory = card.dataset.category;
                const isHidden = card.dataset.hidden === '1';
                const marker = markers[placeId];

                let visible = true;

                if (category && cardCategory !== category) {
                    visible = false;
                }

                if (hiddenOnly && !isHidden) {
                    visible = false;
                }

                card.style.display = visible ? '' : 'none';

                if (marker) {
                    if (visible) {
                        marker.addTo(map);
                    } else {
                        marker.remove();
                    }
                }
            });
        }

        function applySorting() {
            const cards = Array.from(document.querySelectorAll('.place-card'));
            const mode = sortFilter.value;

            cards.sort((a, b) => {
                if (mode === 'name-asc') {
                    return a.dataset.name.localeCompare(b.dataset.name);
                }

                if (mode === 'name-desc') {
                    return b.dataset.name.localeCompare(a.dataset.name);
                }

                if (mode === 'category-asc') {
                    return a.dataset.category.localeCompare(b.dataset.category);
                }

                return 0;
            });

            cards.forEach((card) => placesGrid.appendChild(card));
        }

        categoryFilter.addEventListener('change', applyFilters);
        hiddenFilter.addEventListener('change', applyFilters);
        sortFilter.addEventListener('change', applySorting);
    </script>
{% endblock %}
