{% extends 'base.html.twig' %}

{% block title %}Places · Stray{% endblock %}

{% block body %}
    <main class="container" style="padding: 2rem 0 3rem;">
        <h1>Places</h1>
        <p style="color: var(--muted); margin-bottom: 1.5rem;">
            Explore places on the map and in the list below.
        </p>

        <section style="border: 1px solid var(--border); border-radius: 20px; overflow: hidden; margin-bottom: 2rem;">
            <div id="map" style="height: 400px;"></div>
        </section>

        <section>
            <h2 style="margin-bottom: 1rem;">All places</h2>

            {% if places is empty %}
                <p>No places found yet.</p>
            {% else %}
                <div class="places-grid">
                    {% for place in places %}
                        <a
                            href="{{ path('app_place_detail', { slug: place.slug }) }}"
                            class="place-card"
                            id="place-{{ place.id }}"
                        >
                            <div class="place-category">{{ place.category }}</div>
                            <h3>{{ place.name }}</h3>
                            <p>{{ place.description }}</p>
                            <div class="place-meta">
                                {{ place.latitude }}, {{ place.longitude }}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}

{% block javascripts %}
    <script>
        const map = L.map('map').setView([50.8798, 4.7005], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        {% for place in places %}
        const marker{{ place.id }} = L.marker([{{ place.latitude }}, {{ place.longitude }}])
            .addTo(map)
            .bindPopup("<strong>{{ place.name }}</strong><br>{{ place.category }}");

        marker{{ place.id }}.on('click', function () {
            const el = document.getElementById('place-{{ place.id }}');
            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                el.style.outline = '2px solid #7bd8a5';

                setTimeout(() => {
                    el.style.outline = 'none';
                }, 1500);
            }
        });
        {% endfor %}
    </script>
{% endblock %}
