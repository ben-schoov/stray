{% extends 'base.html.twig' %}

{% block title %}Places · Stray{% endblock %}

{% block body %}
    <main class="container" style="padding: 2rem 0 3rem;">
        <h1>Places</h1>
        <p style="color: var(--muted); margin-bottom: 1.5rem;">
            Explore places on the map and in the list below.
        </p>

        <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
            <select id="category-filter" style="padding: 0.5rem; border-radius: 8px;">
                <option value="">All categories</option>
                <option value="park">Park</option>
                <option value="historic">Historic</option>
                <option value="square">Square</option>
                <option value="museum">Museum</option>
                <option value="viewpoint">Viewpoint</option>
            </select>

            <label style="display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="hidden-filter">
                Hidden gems only
            </label>
        </div>

        <section id="places-map-section" style="border: 1px solid var(--border); border-radius: 20px; overflow: hidden; margin-bottom: 2rem;">
            <div id="map" style="height: 400px;"></div>
        </section>

        <section>
            <h2 style="margin-bottom: 1rem;">All places</h2>

            {% if places is empty %}
                <p>No places found yet.</p>
            {% else %}
                <div class="places-grid">
                    {% for place in places %}
                        <article
                            data-category="{{ place.category }}"
                            data-hidden="{{ place.isHiddenGem ? '1' : '0' }}"
                            class="place-card"
                            id="place-{{ place.id }}"
                            data-place-id="{{ place.id }}"
                            style="cursor: pointer;"
                        >
                            <div class="place-category">{{ place.category }}</div>
                            <h3>{{ place.name }}</h3>
                            <p>{{ place.description }}</p>
                            <div class="place-meta" style="margin-bottom: 1rem;">
                                {{ place.latitude }}, {{ place.longitude }}
                            </div>
                            <a
                                href="{{ path('app_place_detail', { slug: place.slug }) }}"
                                style="display: inline-block; color: var(--accent-2); font-weight: 700;"
                            >
                                View details →
                            </a>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}

{% block javascripts %}
    <script>
        const markers = {};
        const mapSection = document.getElementById('places-map-section');
        const map = L.map('map').setView([50.8798, 4.7005], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        {% for place in places %}
        const marker{{ place.id }} = L.marker([{{ place.latitude }}, {{ place.longitude }}])
            .addTo(map)
            .bindPopup("<strong>{{ place.name }}</strong><br>{{ place.category }}");

        markers[{{ place.id }}] = marker{{ place.id }};

        marker{{ place.id }}.on('click', function () {
            const el = document.getElementById('place-{{ place.id }}');

            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                el.style.outline = '2px solid #7bd8a5';

                setTimeout(() => {
                    el.style.outline = 'none';
                }, 1500);
            }
        });
        {% endfor %}

        document.querySelectorAll('.place-card').forEach((card) => {
            card.addEventListener('click', function (event) {
                if (event.target.tagName.toLowerCase() === 'a') {
                    return;
                }

                const placeId = this.dataset.placeId;
                const marker = markers[placeId];

                if (marker) {
                    mapSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    map.setView(marker.getLatLng(), 15);
                    marker.openPopup();

                    this.style.outline = '2px solid #7bd8a5';

                    setTimeout(() => {
                        this.style.outline = 'none';
                    }, 1500);
                }
            });
        });

        const categoryFilter = document.getElementById('category-filter');
        const hiddenFilter = document.getElementById('hidden-filter');

        function applyFilters() {
            const category = categoryFilter.value;
            const hiddenOnly = hiddenFilter.checked;

            document.querySelectorAll('.place-card').forEach((card) => {
                const cardCategory = card.dataset.category;
                const isHidden = card.dataset.hidden === '1';

                let visible = true;

                if (category && cardCategory !== category) {
                    visible = false;
                }

                if (hiddenOnly && !isHidden) {
                    visible = false;
                }

                card.style.display = visible ? '' : 'none';
            });
        }

        categoryFilter.addEventListener('change', applyFilters);
        hiddenFilter.addEventListener('change', applyFilters);
    </script>
{% endblock %}
